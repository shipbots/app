{
  "manifest_version": 3,
  "name": "ShipBots Customer Service",
  "short_name": "ShipBots CS",
  "version": "0.3.0",
  "description": "Live client search that opens the full client info panel (contact, warehouse, receiving, contracts, sticky notes) in the dashboard. Plus calendar, tasks, and the Mini Apps launcher.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ShipBots Customer Service",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "permissions": ["tabs", "storage"],
  "host_permissions": [
    "https://app-snowy-eight-64.vercel.app/*"
  ]
}
